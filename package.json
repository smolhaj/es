{
  "name": "es",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cf:dev": "wrangler pages dev dist --d1 DB --kv KV --port 8788",
    "cf:deploy": "npm run build && wrangler pages deploy dist",
    "db:migrate": "wrangler d1 execute DB --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute DB --local --file=schema.sql"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "vite": "^5.4.10",
    "wrangler": "^3.89.0"
  }
}
